{
  "name": "giracle-backend",
  "version": "0.23.8-alpha",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "build-win": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ./dist/server ./src/index.ts",
    "build-linux": "bun build --compile --minify-whitespace --minify-syntax --target=bun-linux-x64-modern --outfile ./dist/server ./src/index.ts",
    "build-node-js": "bun build --minify-whitespace --minify-syntax --target=node --outfile ./dist/server-node.js ./src/index.ts",
    "build-bun-js": "bun build --minify-whitespace --minify-syntax --target=bun --outfile ./dist/server-bun.js ./src/index.ts"
  },
  "prisma": {
    "seed": "bun ./prisma/seeds.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "elysia": "^1.4.29",
    "image-size": "^2.0.2",
    "open-graph-scraper": "^6.11.0",
    "prisma": "^7.8.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "bun-types": "^1.3.14"
  },
  "module": "src/index.js"
}
